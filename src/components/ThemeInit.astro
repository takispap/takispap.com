{/* Pre-paint theme restore — sits in <head> so the stored choice applies before first paint. System preference stays the default when nothing is stored. */}
<script is:inline>
	(() => {
		try {
			const t = localStorage.getItem('tp-theme');
			if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
		} catch {}
	})();
</script>
