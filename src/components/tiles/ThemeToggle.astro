---
// System-default theme with a manual override (takis, 2026-07-12). Cycles system → dark → light.
// v2: icon morph (monitor/moon/sun) + circular view-transition reveal from the button —
// clever but intuitive; falls back to an instant swap without JS, View Transitions, or with reduced motion.
import monitor from '../../assets/icons/monitor.svg?raw';
import moon from '../../assets/icons/moon.svg?raw';
import sun from '../../assets/icons/sun.svg?raw';
---

<button type="button" id="theme-toggle" data-mode="system" aria-label="Theme: following your system. Click to switch." title="Theme: system">
	<span class="tt-icon tt-system" set:html={monitor} />
	<span class="tt-icon tt-dark" set:html={moon} />
	<span class="tt-icon tt-light" set:html={sun} />
	<span class="tt-sr" aria-live="polite"></span>
</button>

<style is:global>
	#theme-toggle { position: relative; display: inline-grid; place-items: center; }
	#theme-toggle .tt-icon { grid-area: 1 / 1; display: inline-flex; opacity: 0; scale: 0.6; rotate: -60deg; transition: opacity 200ms ease, scale 250ms cubic-bezier(0.2, 0.7, 0.2, 1), rotate 250ms cubic-bezier(0.2, 0.7, 0.2, 1); }
	#theme-toggle .tt-icon svg { inline-size: 1.15em; block-size: 1.15em; display: block; }
	#theme-toggle[data-mode='system'] .tt-system,
	#theme-toggle[data-mode='dark'] .tt-dark,
	#theme-toggle[data-mode='light'] .tt-light { opacity: 1; scale: 1; rotate: 0deg; }
	.tt-sr { position: absolute; inline-size: 1px; block-size: 1px; overflow: hidden; clip-path: inset(50%); white-space: nowrap; }
	/* the circular reveal drives the swap — stop the default crossfade fighting it */
	::view-transition-old(root), ::view-transition-new(root) { animation: none; mix-blend-mode: normal; }
	@media (prefers-reduced-motion: reduce) { #theme-toggle .tt-icon { transition: none; } }
</style>

<script is:inline>
	(() => {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;
		const modes = ['system', 'dark', 'light'];
		const labels = {
			system: 'Theme: following your system. Click to switch.',
			dark: 'Theme: dark. Click to switch.',
			light: 'Theme: light. Click to switch.',
		};
		const setMode = (mode) => {
			if (mode === 'system') {
				delete document.documentElement.dataset.theme;
				try { localStorage.removeItem('tp-theme'); } catch {}
			} else {
				document.documentElement.dataset.theme = mode;
				try { localStorage.setItem('tp-theme', mode); } catch {}
			}
			btn.dataset.mode = mode;
			btn.setAttribute('aria-label', labels[mode]);
			btn.title = 'Theme: ' + mode;
			btn.querySelector('.tt-sr').textContent = 'Theme set to ' + mode;
		};
		let mode = document.documentElement.dataset.theme || 'system';
		btn.dataset.mode = mode;
		btn.setAttribute('aria-label', labels[mode]);
		btn.title = 'Theme: ' + mode;
		btn.addEventListener('click', () => {
			mode = modes[(modes.indexOf(mode) + 1) % modes.length];
			const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (!document.startViewTransition || reduced) { setMode(mode); return; }
			const r = btn.getBoundingClientRect();
			const x = r.left + r.width / 2;
			const y = r.top + r.height / 2;
			const radius = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
			const vt = document.startViewTransition(() => setMode(mode));
			vt.ready.then(() => {
				document.documentElement.animate(
					{ clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${radius}px at ${x}px ${y}px)`] },
					{ duration: 780, easing: 'cubic-bezier(0.65, 0, 0.35, 1)', pseudoElement: '::view-transition-new(root)' },
				);
			}).catch(() => {});
		});
	})();
</script>
