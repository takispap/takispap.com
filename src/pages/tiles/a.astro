---
import { Font } from 'astro:assets';
import ThemeInit from '../../components/tiles/ThemeInit.astro';
import ThemeToggle from '../../components/tiles/ThemeToggle.astro';
import Icon from '../../components/tiles/Icon.astro';
import Mark from '../../components/tiles/Mark.astro';

// per-word reveal helpers — static spans, no client JS.
// Each word = clip box (.w) + inner riser (.wi): words rise from behind their line, lusion-register.
const words = (s) => s.split(' ');
const heroLine = 'Making complex things clear.';
const heroSub = 'Twenty years through paper, web, VR, design systems and AI. The medium keeps changing; the job hasn’t.';
const feelLead = 'A dark, warm room where type does the talking and the cinematic layer earns its keep. Bold and wide when it speaks, quiet everywhere else. Personality from words, motion and interaction — never decoration.';
const bioLead = 'I’ve designed food-delivery flows, VR tours of ancient stadiums, enterprise design systems and a gaming social network. The thesis project lost its domain and the VR startup never found funding — both taught me more than the wins that followed.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="robots" content="noindex, nofollow" />
		<meta name="generator" content={Astro.generator} />
		<title>Tile A v3 — Warm cinematic dark</title>
		<Font cssVariable="--font-archivo" preload />
		<Font cssVariable="--font-mono" />
		<ThemeInit />
	</head>
	<body>
		<header class="site">
			<a class="mark" href="/tiles/" aria-label="Back to tile index"><Mark size={38} /></a>
			<nav class="nav-sample" aria-label="Sample navigation">
				<a class="u-link is-current" href="/tiles/a" aria-current="page">Work</a>
				<a class="u-link" href="/tiles/">Writing</a>
				<a class="u-link" href="/tiles/">Lab</a>
				<a class="u-link" href="/tiles/">About</a>
			</nav>
			<ThemeToggle />
		</header>

		<main>
			<section class="hero">
				<p class="eyebrow" style="view-transition-name: tile-a">Takis Papadopoulos · Senior product designer · Athens</p>
				<h1 class="display intro-words">
					{words(heroLine).map((w, i) => <span class={`w${w.startsWith('clear') ? ' w-accent' : ''}`} style={`--i:${i}`}><span class="wi">{w}</span></span>)}
				</h1>
				<p class="sub intro-words">
					{words(heroSub).map((w, i) => <span class="w" style={`--i:${i + 5}`}><span class="wi">{w}</span></span>)}
				</p>
			</section>

			<section class="reveal" aria-labelledby="feel-h">
				<h2 id="feel-h">Feel</h2>
				<p class="lead reveal-words">
					{words(feelLead).map((w, i) => <span class="w" style={`--i:${i % 14}`}><span class="wi">{w}</span></span>)}
				</p>
				<p class="chips" role="list">
					<span class="chip" role="listitem">minimal</span>
					<span class="chip" role="listitem">typographic</span>
					<span class="chip" role="listitem">cinematic</span>
					<span class="chip" role="listitem">warm</span>
					<span class="chip" role="listitem">honest</span>
				</p>
			</section>

			<section class="reveal" aria-labelledby="type-h">
				<h2 id="type-h">Type</h2>
				<p class="spec-note prose-measure">Stand-in face (fonts decided later, takis's call): <strong>Archivo</strong> variable — weight 100–900, width 62–125%. Display runs wide and heavy; body runs normal.</p>
				<div class="specimen">
					<p class="spec display">Display / 11vw</p>
					<p class="spec t-h1">Heading 1 / clamp(2.1–3.5rem)</p>
					<p class="spec t-h2">Heading 2 / clamp(1.65–2.35rem)</p>
					<p class="spec t-h3">Heading 3 / clamp(1.3–1.65rem)</p>
					<p class="spec t-h4">Heading 4 / clamp(1.08–1.25rem)</p>
					<p class="spec t-body prose-measure">Body / clamp(1–1.35rem) — measure stays readable (~72ch) inside the fluid layout, line-height 1.6, real quotes “like so”, en-dashes – and tabular numerals 0123456789.</p>
					<p class="spec t-small">Small / 0.875rem — metadata, dates.</p>
					<p class="spec t-caption">Caption / 0.8125rem — the quietest voice in the room.</p>
					<p class="spec t-micro">Micro / 0.75rem tracked caps — eyebrows, indexes, tags; the one size that never scales.</p>
					<p class="spec t-mono">Mono / JetBrains Mono VF — code, tokens, the occasional shell prompt.</p>
				</div>
			</section>

			<section class="reveal" aria-labelledby="colour-h">
				<h2 id="colour-h">Colour</h2>
				<p class="prose-measure">Warm charcoal, warm bone, one amber accent. No pure black or white. Tokens in OKLCH with hex fallbacks, themed via <code>light-dark()</code> — system default; the header switch overrides with a circular reveal (instant under reduced motion). The inline tp mark keeps its own fill tokens, so it can re-colour and animate.</p>
				<div class="swatches">
					<div class="swatch sw-bg"><span>--bg</span></div>
					<div class="swatch sw-raised"><span>--bg-raised</span></div>
					<div class="swatch sw-text"><span>--text</span></div>
					<div class="swatch sw-muted"><span>--text-muted</span></div>
					<div class="swatch sw-accent"><span>--accent</span></div>
					<div class="swatch sw-border"><span>--border</span></div>
				</div>
				<table>
					<caption>Measured contrast (WCAG 2.2) — also the table component sample</caption>
					<thead>
						<tr><th scope="col">Pair</th><th scope="col">Dark theme</th><th scope="col">Light theme</th><th scope="col">Floor</th></tr>
					</thead>
					<tbody>
						<tr><td>text / bg</td><td>15.63:1</td><td>16.00:1</td><td>4.5:1</td></tr>
						<tr><td>muted / bg</td><td>6.80:1</td><td>5.72:1</td><td>4.5:1</td></tr>
						<tr><td>accent / bg</td><td>8.48:1</td><td>5.43:1</td><td>4.5:1</td></tr>
						<tr><td>text / raised</td><td>14.27:1</td><td>15.20:1</td><td>4.5:1</td></tr>
					</tbody>
				</table>
			</section>

			<section class="reveal" aria-labelledby="space-h">
				<h2 id="space-h">Space &amp; layout</h2>
				<p class="prose-measure">No fixed page width: the layout breathes with the screen through fluid side paddings (<code>max(1.25rem, 5vw)</code>, uncapped) — cap the type, never the layout; empty space does the composing. Corners round where the hand goes — buttons run pill, cards and code round with a radius that scales with the screen (clamp), text and structure stay quiet.</p>
				<div class="space-bars">
					<div style="inline-size: var(--space-1)"><span>1 · 0.25rem</span></div>
					<div style="inline-size: var(--space-2)"><span>2 · 0.5rem</span></div>
					<div style="inline-size: var(--space-3)"><span>3 · 1rem</span></div>
					<div style="inline-size: var(--space-4)"><span>4 · 1.5rem</span></div>
					<div style="inline-size: var(--space-5)"><span>5 · 2.5rem</span></div>
					<div style="inline-size: var(--space-6)"><span>6 · 4rem</span></div>
					<div style="inline-size: var(--space-7)"><span>7 · 6.5rem</span></div>
				</div>
			</section>

			<section class="reveal" aria-labelledby="comp-h">
				<h2 id="comp-h">Components</h2>

				<p class="lead reveal-words prose-measure">
					{words(bioLead).map((w, i) => <span class="w" style={`--i:${i % 14}`}><span class="wi">{w}</span></span>)}
				</p>
				<p class="t-body prose-measure">These days I split my time between product work and <a href="/tiles/">Zeus</a>, the local-AI studio humming under my desk.</p>

				<div class="btn-row">
					<a class="btn btn-primary" href="/tiles/">Read the case study <Icon name="arrow-right" /></a>
					<a class="btn btn-secondary" href="/tiles/">Download CV <Icon name="download" /></a>
					<a class="btn btn-ghost" href="/tiles/">All experiments <Icon name="arrow-up-right" /></a>
				</div>

				<div class="card-row">
					<article class="card">
						<p class="chip">design systems</p>
						<h3 class="t-h3">BETA CAE — one system, three realities</h3>
						<p class="t-small">Five years building a design system that spans desktop, web and VR/AR for an engineering suite — one language across every screen and headset.</p>
						<a class="card-link u-link" href="/tiles/">Read the case study <Icon name="arrow-up-right" /></a>
					</article>
					<article class="card">
						<p class="chip chip-live">live</p>
						<h3 class="t-h3">Zeus — the local AI studio</h3>
						<p class="t-small">Agents, voice, image generation — running on one stubborn GPU in Athens. Self-funded; self-inflicted.</p>
						<a class="card-link u-link" href="/tiles/">See the experiments <Icon name="arrow-up-right" /></a>
					</article>
				</div>

				<aside class="callout">
					<p class="t-small"><strong>Token discipline.</strong> Every visual decision on this page is a custom property — including the mark's fills and every icon's colour (all SVG inline). Change once, changes everywhere; the contract lives in <code>design.md</code>.</p>
				</aside>

				<figure>
					<pre class="code"><code>/* per-word reveal — static spans + CSS scroll timeline, zero JS */
.reveal-words .w &#123;
  animation: word-in 1ms linear both;
  animation-timeline: view();
  animation-range: entry calc(8% + var(--i) * 2.5%)
                   entry calc(38% + var(--i) * 2.5%);
&#125;</code></pre>
					<figcaption class="t-caption">Figure + caption sample. Real code — it drives the paragraphs above.</figcaption>
				</figure>
			</section>

			<section class="reveal" aria-labelledby="motion-h">
				<h2 id="motion-h">Motion &amp; micro-interactions</h2>
				<ul class="prose-measure motion-list">
					<li><strong>Intro:</strong> header settles down, hero words rise one by one on load.</li>
					<li><strong>Appear:</strong> sections lift as they enter the viewport (CSS scroll timeline).</li>
					<li><strong>Scroll reveal, per word:</strong> lead paragraphs sharpen from subtle to normal as you scroll — try the Feel and Components sections.</li>
					<li><strong>Hover:</strong> nav links draw their underline; button icons nudge along their direction of travel; cards lift and warm their border.</li>
					<li><strong>Click:</strong> buttons compress slightly on press.</li>
					<li><strong>Theme switch:</strong> icon morph + circular reveal sweeping from the button (View Transition; instant under reduced motion).</li>
					<li><strong>Signature:</strong> cross-document View Transition — <a href="/tiles/">back to the index</a>, the tile title morphs.</li>
					<li><strong>Focus:</strong> keyboard Tab paints a subtle amber halo around anything interactive — try it.</li>
					<li><strong>Reduced motion:</strong> every one of the above collapses to plain visibility. Content never waits for motion.</li>
				</ul>
			</section>

			<section class="reveal" aria-labelledby="nf-h">
				<h2 id="nf-h">404 sample</h2>
				<div class="frame-404">
					<p class="display nf-code">404</p>
					<p class="t-h3">Nothing here but very good kerning.</p>
					<p class="t-small">Either the link is old or I broke it. My money's on me.</p>
					<a class="btn btn-primary" href="/tiles/">Go home <Icon name="arrow-right" /></a>
				</div>
			</section>

			<footer class="colophon">
				<p class="t-caption">A v3 — takis's working direction (2026-07-12): viewport-sized display + invariant micro register (adaptive-scale study, design.md §0.5) · hero = full-viewport statement frame · per-word scroll reveal · fluid full-width layout, uncapped gutters · all SVG inline (tp mark fill-tokenised; icons = <a href="https://lucide.dev">Lucide</a>, ISC, placeholders until takis draws his own) · theme switch with circular reveal · focus halo · rounded where the hand goes.</p>
				<p class="t-caption">Fonts deferred (Archivo stands in). Theme: system default + override. Colours: OKLCH via <code>light-dark()</code>, hex fallback = dark set. Style tile — superseded sections get deleted as design.md forms.</p>
			</footer>
		</main>
	</body>
</html>

<style is:global>
	:root { color-scheme: light dark; }
	:root[data-theme='light'] { color-scheme: light; }
	:root[data-theme='dark'] { color-scheme: dark; }
	@view-transition { navigation: auto; }

	:root {
		/* ---- Tile A tokens. Hex fallback = dark (home theme); capable browsers get OKLCH light-dark() ---- */
		--bg: #161210;
		--bg: light-dark(oklch(97.2% 0.011 76.6), oklch(18.6% 0.008 48.3));
		--bg-raised: #221b15;
		--bg-raised: light-dark(oklch(94.3% 0.018 78.2), oklch(22.8% 0.016 62.5));
		--text: #f2eae1;
		--text: light-dark(oklch(22% 0.016 62.5), oklch(94.1% 0.015 70.9));
		--text-muted: #a89a8c;
		--text-muted: light-dark(oklch(49.3% 0.025 69.4), oklch(69.4% 0.026 67.4));
		--accent: #e8a04c;
		--accent: light-dark(oklch(50.9% 0.096 67.6), oklch(76.1% 0.131 67.6));
		--accent-contrast: #161210;
		--accent-contrast: light-dark(oklch(97.2% 0.011 76.6), oklch(18.6% 0.008 48.3));
		--border: #3a312a;
		--border: light-dark(oklch(87.2% 0.027 76.8), oklch(32.1% 0.018 60));

		/* type — cap type, never layout (design.md §0.5): display is viewport-sized,
		   body rides clamp rails, micro register never scales */
		--size-display: clamp(3rem, 11vw, 26rem);
		--size-h1: clamp(2.1rem, 1.4rem + 2.8vw, 3.5rem);
		--size-h2: clamp(1.65rem, 1.3rem + 1.4vw, 2.35rem);
		--size-h3: clamp(1.3rem, 1.15rem + 0.7vw, 1.65rem);
		--size-h4: clamp(1.08rem, 0.95rem + 0.55vw, 1.9rem);
		--size-body: clamp(1rem, 0.94rem + 0.25vw, 1.35rem);
		--size-small: 0.875rem;
		--size-caption: 0.8125rem;
		--size-micro: 0.75rem;

		/* space + fluid gutters (no fixed page width, uncapped) */
		--space-1: 0.25rem; --space-2: 0.5rem; --space-3: 1rem; --space-4: 1.5rem;
		--space-5: 2.5rem; --space-6: 4rem; --space-7: 6.5rem;
		--pad-x: max(1.25rem, 5vw);

		/* motion — fluid and eased (lusion register): quick for presses, base for hovers, slow for sweeps */
		--motion-quick: 140ms;
		--motion-base: 400ms;
		--motion-slow: 780ms;
		--ease-out: cubic-bezier(0.2, 0.7, 0.2, 1);
		--ease-fluid: cubic-bezier(0.65, 0, 0.35, 1);
		--ease-settle: cubic-bezier(0.16, 1, 0.3, 1);

		/* corners — rounded where the hand goes, radius scales with the screen */
		--radius-s: clamp(6px, 0.4vw + 4px, 10px);
		--radius-m: clamp(12px, 1vw + 8px, 20px);
		--radius-l: clamp(18px, 2vw + 12px, 34px);

		/* focus halo */
		--halo: 0 0 0 2px var(--bg), 0 0 0 6px color-mix(in oklab, var(--accent) 45%, transparent);
	}

	/* display recomputes per context: phones re-wrap big (never shrink relative to
	   the screen), ultrawides get reined in — design.md §2 */
	@media (max-width: 700px) { :root { --size-display: clamp(2.6rem, 17vw, 8rem); } }
	@media (min-aspect-ratio: 21/9) { :root { --size-display: clamp(3rem, 8vw, 22rem); } }

	* { box-sizing: border-box; margin: 0; }
	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--font-archivo), system-ui, sans-serif;
		font-size: var(--size-body);
		line-height: 1.6;
	}
	:focus-visible { outline: 2px solid transparent; border-radius: var(--radius-s); box-shadow: var(--halo); transition: box-shadow var(--motion-quick) var(--ease-out); }
	a { color: var(--accent); text-underline-offset: 0.2em; }
	.prose-measure { max-width: 72ch; }

	/* header / nav */
	.site { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-4) var(--pad-x); }
	.mark { display: inline-flex; border-radius: 999px; }
	.mark .tp-mark { transition: rotate var(--motion-base) var(--ease-settle), scale var(--motion-base) var(--ease-settle); }
	.mark:hover .tp-mark, .mark:focus-visible .tp-mark { rotate: -8deg; scale: 1.06; }
	.nav-sample { display: flex; gap: var(--space-4); flex-wrap: wrap; }
	@media (max-width: 700px) { .site, .nav-sample { gap: var(--space-3); } }
	.u-link {
		color: var(--text); text-decoration: none; font-weight: 550; padding-block: 0.15rem;
		background-image: linear-gradient(var(--accent), var(--accent));
		background-size: 0% 2px; background-position: 0 100%; background-repeat: no-repeat;
		transition: background-size var(--motion-base) var(--ease-settle), color var(--motion-quick) var(--ease-out);
	}
	.u-link:hover, .u-link:focus-visible { background-size: 100% 2px; }
	.u-link.is-current { color: var(--accent); background-size: 100% 2px; }
	#theme-toggle {
		font: inherit; font-size: 1rem; cursor: pointer; padding: 0.55rem 0.7rem;
		border-radius: 999px; border: 1px solid var(--border); background: var(--bg-raised); color: var(--text);
		transition: border-color var(--motion-quick) var(--ease-out), scale var(--motion-quick) var(--ease-out);
	}
	#theme-toggle:hover { border-color: var(--accent); }
	#theme-toggle:active { scale: 0.94; }

	main { padding-inline: var(--pad-x); }
	main > section { margin-block-end: var(--space-7); }
	h2 { font-size: var(--size-h2); font-weight: 750; letter-spacing: -0.015em; margin-block-end: var(--space-4); }
	.lead { font-size: var(--size-h4); }

	/* hero = full-viewport statement frame (design.md §0.5): micro label top,
	   viewport-sized display anchored low-left, spine sentence parked lower-right */
	.hero { min-block-size: calc(100svh - 7rem); display: grid; grid-template-rows: auto 1fr auto; padding-block: var(--space-5) var(--space-6); }
	.eyebrow { font-size: var(--size-micro); color: var(--text-muted); letter-spacing: 0.14em; text-transform: uppercase; }
	.hero .display { align-self: end; margin-block-end: var(--space-5); }
	.display {
		font-size: var(--size-display);
		font-weight: 840;
		font-stretch: 125%;
		line-height: 0.98;
		letter-spacing: -0.025em;
		margin-block-end: var(--space-4);
	}
	.display .w-accent .wi { color: var(--accent); }
	.sub { font-size: var(--size-h4); color: var(--text-muted); max-width: 40ch; justify-self: end; }
	@media (max-width: 700px) { .sub { justify-self: start; } }

	/* per-word spans — clip box + riser: words rise from behind their own line */
	.intro-words .w, .reveal-words .w { display: inline-block; overflow: hidden; vertical-align: bottom; padding-block-end: 0.06em; margin-block-end: -0.06em; }
	.intro-words .w { margin-inline-end: 0.24em; }
	.reveal-words .w { margin-inline-end: 0.22em; }
	.w .wi { display: inline-block; }

	/* type specimen */
	.spec-note { color: var(--text-muted); margin-block-end: var(--space-4); }
	.specimen { display: grid; gap: var(--space-3); border-block: 1px solid var(--border); padding-block: var(--space-4); }
	.spec.display { margin: 0; }
	.t-h1 { font-size: var(--size-h1); font-weight: 800; font-stretch: 118%; letter-spacing: -0.02em; line-height: 1.05; }
	.t-h2 { font-size: var(--size-h2); font-weight: 750; letter-spacing: -0.015em; }
	.t-h3 { font-size: var(--size-h3); font-weight: 700; }
	.t-h4 { font-size: var(--size-h4); font-weight: 650; }
	.t-body { font-size: var(--size-body); font-variant-numeric: tabular-nums; }
	.t-small { font-size: var(--size-small); color: var(--text-muted); }
	.t-caption { font-size: var(--size-caption); color: var(--text-muted); }
	.t-mono { font-family: var(--font-mono), monospace; font-size: var(--size-small); }
	.t-micro { font-size: var(--size-micro); letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); }

	/* colour */
	.swatches { display: grid; grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr)); gap: var(--space-2); margin-block: var(--space-4); }
	.swatch { border-radius: var(--radius-s); border: 1px solid var(--border); padding: var(--space-4) var(--space-3); font-family: var(--font-mono), monospace; font-size: var(--size-caption); }
	.sw-bg { background: var(--bg); }
	.sw-raised { background: var(--bg-raised); }
	.sw-text { background: var(--text); color: var(--bg); }
	.sw-muted { background: var(--text-muted); color: var(--bg); }
	.sw-accent { background: var(--accent); color: var(--accent-contrast); }
	.sw-border { background: var(--border); }
	table { border-collapse: collapse; font-variant-numeric: tabular-nums; font-size: var(--size-small); }
	caption { text-align: left; color: var(--text-muted); font-size: var(--size-caption); margin-block-end: var(--space-2); }
	th, td { text-align: left; padding: var(--space-2) var(--space-4) var(--space-2) 0; border-bottom: 1px solid var(--border); }

	/* space bars */
	.space-bars { display: grid; gap: var(--space-2); margin-block-start: var(--space-4); }
	.space-bars div { background: var(--accent); block-size: 1.1rem; border-radius: 3px; position: relative; min-inline-size: 2px; }
	.space-bars span { position: absolute; inset-inline-start: calc(100% + 0.75rem); top: 50%; translate: 0 -50%; font-family: var(--font-mono), monospace; font-size: var(--size-caption); color: var(--text-muted); white-space: nowrap; }

	/* components */
	.chips { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-block-start: var(--space-3); }
	.chip { display: inline-block; font-size: var(--size-caption); border: 1px solid var(--border); border-radius: 999px; padding: 0.2rem 0.7rem; color: var(--text-muted); }
	.chip-live { color: var(--accent); border-color: var(--accent); }
	.btn-row { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-block: var(--space-5); }
	.btn {
		display: inline-flex; align-items: center; gap: 0.55rem;
		padding: 0.75em 1.5em; border-radius: 999px; font-weight: 650; text-decoration: none;
		transition: translate var(--motion-base) var(--ease-settle), scale var(--motion-quick) var(--ease-out), border-color var(--motion-base) var(--ease-settle), background var(--motion-base) var(--ease-settle);
	}
